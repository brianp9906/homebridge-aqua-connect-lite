  "version": "1.4.1",
  "description": "Homebridge plugin for Aqua Connect Lite pool controllers, compatible with Homebridge v1 and v2.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brianp9906/homebridge-aqua-connect-lite.git"
  },
