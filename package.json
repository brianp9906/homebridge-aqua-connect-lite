    "@typescript-eslint/eslint-plugin": "^5.30.3",
    "@typescript-eslint/parser": "^5.30.3",
    "eslint": "^8.19.0",
    "homebridge": "^1.3.5",
    "nodemon": "^3.0.0",
    "rimraf": "^3.0.2",
